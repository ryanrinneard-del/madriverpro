{
  "functions": {
    "api/generate-pdfs.py": {
      "runtime": "@vercel/python@4.3.1",
      "maxDuration": 60
    },
    "api/process-profile.js": {
      "maxDuration": 60
    },
    "api/approve-profile.js": {
      "maxDuration": 30
    },
    "api/generate-game-plan.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://*.public.blob.vercel-storage.com https://*.supabase.co wss://*.supabase.co; frame-ancestors 'none'" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/Articles/:path*",
      "destination": "/articles/:path*",
      "permanent": true
    },
    {
      "source": "/portal",
      "destination": "/portal/",
      "permanent": true
    },
    {
      "source": "/adult",
      "destination": "/adult/",
      "permanent": true
    },
    {
      "source": "/improve",
      "destination": "/improve/",
      "permanent": true
    }
  ]
}
