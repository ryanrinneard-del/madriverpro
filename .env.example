# Environment variables required by the profile-review pipeline.
# Copy to .env.local for local dev (with `vercel dev`) and set each in the
# Vercel dashboard (Project → Settings → Environment Variables) for prod.

# --- Anthropic (profile analysis) ---
# Create/copy from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Resend (outbound email to students + Ryan) ---
# Create/copy from https://resend.com/api-keys
RESEND_API_KEY=
# Optional — defaults to "Ryan Rinneard <ryan@madriverpro.com>".
# Must be a verified sending address in Resend (the domain needs SPF/DKIM set).
RESEND_FROM_EMAIL=

# --- Admin auth for /admin/profile-review ---
# Strong passphrase. This is the ONLY thing gating the dashboard.
ADMIN_PASSWORD=
# Optional — used to sign the session cookie. Falls back to ADMIN_PASSWORD if
# unset, but it's better to have a dedicated 32+ character random secret here.
ADMIN_SESSION_SECRET=

# --- Internal pipeline token (stops random traffic from triggering /api/generate-pdfs) ---
# Any long random string. Must be identical in both places it's referenced.
INTERNAL_PIPELINE_TOKEN=

# --- Vercel Blob (auto-provisioned when you add the integration) ---
# Vercel sets this for you when you attach a Blob store to the project.
# You should NOT need to paste it manually.
BLOB_READ_WRITE_TOKEN=

# --- Existing (already in use by /api/subscribe.js) ---
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
MAILCHIMP_SERVER=us17
